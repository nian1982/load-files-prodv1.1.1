# ── versionamiento docker compose ─────────────────────────────
IMAGE_NAME=softrondev/load-files
IMAGE_VERSION=1.0.1
IMAGE_ENV=prod

# ── SFTP ─────────────────────────────────────────────────────
SFTP_HOST=localhost
SFTP_PORT=4223
SFTP_USER=sftpuser
SFTP_PASS=Bogota2026!
SFTP_UPLOAD_DIR=/upload

# ── Archivos permitidos ──────────────────────────────────────
ALLOWED_FILE_TYPES=REPOSITORIO,FACTURAS,INFORMES
ALLOWED_EXTENSIONS=.xlsx,.xls,.csv,.pdf
MAX_UPLOAD_SIZE_MB=500

# ── Keycloak ──────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=muhoco
KEYCLOAK_CLIENT_ID=api-load-files
KEYCLOAK_VERIFY_AUDIENCE=false

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
TEMP_UPLOAD_DIR=/dev/shm/load_files_uploads
SFTP_CHUNK_SIZE=4194304

# ── Logs (producción se auto-forza a WARNING) ────────────────
# LOG_LEVEL_OVERRIDE=DEBUG    # Solo para emergencias en prod
