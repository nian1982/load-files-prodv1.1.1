# ── Entorno ───────────────────────────────────────────────────
APP_NAME=Load Files Service
APP_VERSION=1.0.0
# Local:   ENVIRONMENT=development
# Docker:  ENVIRONMENT=production

# ── SFTP ─────────────────────────────────────────────────────
# Local:   SFTP_HOST=127.0.0.1
# Docker:  SFTP_HOST=host.docker.internal
SFTP_PORT=4223
SFTP_USER=sftpuser
SFTP_PASS=Bogota2026!
SFTP_UPLOAD_DIR=/upload

# ── Archivos permitidos ──────────────────────────────────────
ALLOWED_FILE_TYPES=REPOSITORIO,FACTURAS,INFORMES
ALLOWED_EXTENSIONS=.xlsx,.xls,.csv,.pdf
MAX_UPLOAD_SIZE_MB=500

# ── Keycloak ──────────────────────────────────────────────────
# Local:   KEYCLOAK_URL=http://localhost:8080
# Docker:  KEYCLOAK_URL=http://host.docker.internal:8080
KEYCLOAK_REALM=muhoco
KEYCLOAK_CLIENT_ID=api-load-files
KEYCLOAK_VERIFY_AUDIENCE=false

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://192.168.1.9:6379/0
TEMP_UPLOAD_DIR=/dev/shm/load_files_uploads
SFTP_CHUNK_SIZE=4194304

# ── Logs ─────────────────────────────────────────────────────
# LOG_LEVEL_OVERRIDE=DEBUG
